  "keyFeatures": [
    "Headless, unstyled components with full styling flexibility",
    "Composable API design with compound component patterns",
    "Tree-shakeable ESM modules for optimal bundle sizes",
    "Full TypeScript support with excellent type inference",
    "Built on @zayne-labs/toolkit for robust utilities",
    "Data attributes for consistent styling targets",
    "Framework-agnostic architecture (React available, more coming)"
  ],
  "publicApiSurface": [
    "@zayne-labs/ui-react/ui/card - Card component with Root, Header, Title, Description, Content, Footer parts",
    "@zayne-labs/ui-react/ui/carousel - Carousel component with Root, ItemList, Item, Controls, Button, Indicator parts",
    "@zayne-labs/ui-react/ui/drag-scroll - DragScroll component for drag-to-scroll behavior",
    "@zayne-labs/ui-react/ui/drop-zone - DropZone component with file upload and drag-and-drop support",
    "@zayne-labs/ui-react/ui/form - Form component with validation (wrapper around react-hook-form)",
    "@zayne-labs/ui-react/common/await - Await component for declarative async state handling",
    "@zayne-labs/ui-react/common/client-gate - ClientGate component for client-side only rendering",
    "@zayne-labs/ui-react/common/error-boundary - ErrorBoundary component for error handling",
    "@zayne-labs/ui-react/common/for - For component for list rendering with keying",
    "@zayne-labs/ui-react/common/presence - Presence component for animation detection",
    "@zayne-labs/ui-react/common/show - Show component for conditional rendering",
    "@zayne-labs/ui-react/common/slot - Slot component for component composition",
    "@zayne-labs/ui-react/common/suspense-with-boundary - Combined Suspense and ErrorBoundary",
    "@zayne-labs/ui-react/common/switch - Switch component for pattern matching",
    "@zayne-labs/ui-react/common/teleport - Teleport component for portal-based rendering"
  ]
}
